# ========== LLM ==========
JUDGE_MODEL_NAME=qwen3.5-plus-2026-02-15
API_KEY=your-dashscope-api-key
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== SiliconFlow (Embedding + Reranker) ==========
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ========== Embedding ==========
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ========== Reranker ==========
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ========== MinerU API (可选，留空则使用本地 magic-pdf) ==========
MINERU_API_KEY=your-mineru-api-key

# ========== MySQL ==========
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=finance_brain

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== Milvus ==========
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ========== Neo4j ==========
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ========== CORS ==========
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:5173

# ========== File Storage ==========
UPLOAD_DIR=uploads

# ========== JWT ==========
JWT_SECRET_KEY=替换为随机生成的密钥（可用 python -c "import secrets; print(secrets.token_urlsafe(48))" 生成）
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== LANGSMITH ==========
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=fintech_brain
